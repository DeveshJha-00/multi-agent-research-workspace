# Required model/search credentials
GROQ_API_KEY=replace-me
TAVILY_API_KEY=replace-me

# Application
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:8501"]
LLM_PROVIDER=groq
GROQ_CHAT_MODEL=openai/gpt-oss-20b
GROQ_MAX_OUTPUT_TOKENS=1200
GROQ_REQUESTS_PER_SECOND=0.2
EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
FASTEMBED_CACHE_DIR=/models/fastembed
EMBEDDING_DIMENSIONS=384
RERANKER_MODEL=ms-marco-TinyBERT-L-2-v2
RERANKER_CACHE_DIR=/models/flashrank

# Qdrant (the local Docker Compose values work as-is after changing the key)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=replace-with-a-long-random-key
QDRANT_COLLECTION=agentic_workspace_bge_v1

# MongoDB
MONGO_ROOT_USERNAME=adaptive_rag
MONGO_ROOT_PASSWORD=replace-with-a-long-random-password
MONGODB_URL=mongodb://adaptive_rag:replace-with-a-long-random-password@mongo:27017/adaptive_rag?authSource=admin
MONGODB_DB_NAME=adaptive_rag

# Retrieval and ingestion tuning
RETRIEVAL_TOP_K=12
RERANK_TOP_N=5
RETRIEVAL_SCORE_THRESHOLD=0.2
RERANK_RELEVANCE_THRESHOLD=0.45
MAX_RETRIEVAL_RETRIES=1
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MAX_UPLOAD_BYTES=20971520
MAX_HISTORY_MESSAGES=30
AGENT_MAX_ITERATIONS=3
SUPERVISOR_MAX_WORKERS=2
AGENT_MAX_REVISIONS=1
GRAPH_RECURSION_LIMIT=15
RESEARCH_WORKER_POLL_SECONDS=1.0
RESEARCH_JOB_LEASE_SECONDS=60
RESEARCH_JOB_MAX_ATTEMPTS=3
RESEARCH_EVENT_POLL_SECONDS=0.5
AGENT_TOOL_RESULT_CHARS=8000
CRITIC_RESULTS_CHARS=3000
CRITIC_EVIDENCE_CHARS=6000
MAX_DATASET_UPLOAD_BYTES=10485760
MAX_DATASET_ROWS=10000
MAX_DATASET_COLUMNS=100
MAX_REPOSITORY_UPLOAD_BYTES=10485760
MAX_REPOSITORY_FILES=1000
MAX_REPOSITORY_FILE_BYTES=524288
MAX_REPOSITORY_TOTAL_BYTES=20971520
REPOSITORY_SEARCH_MAX_MATCHES=50
REPOSITORY_EXPLANATION_CONTEXT_CHARS=14000
REPOSITORY_EXPLANATION_OUTPUT_TOKENS=1800

# Used by the Streamlit container
RAG_API_URL=http://api:8000
RAG_REQUEST_TIMEOUT_SECONDS=300
